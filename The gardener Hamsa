#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define tc int t; cin>>t; while (t--)
#define en '\n'
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    cout.tie(NULL);
    ll n;
    cin>>n;
    vector<ll>v(n);
    vector<ll>v2(n);
    cin>>v[0];
    v2[0]=v[0];
    for(ll i=1;i<n;i++)
        {cin>>v2[i];v[i]=v2[i]+v[i-1];}
    sort(v2.begin(),v2.end());
    for(ll i=1;i<n;i++)
        v2[i]=v2[i]+v2[i-1];
 
    tc
    {
        ll sum=0;
        int l,r,k;
        cin>>k>>l>>r;
        if(k==1)
        {
            if(l!=1)
                sum=v[r-1]-v[l-2];
            else if (r==l)
                sum=v[r-1];
            else if (l==1)
                sum=v[r-1];
        }
        else if (k==2)
        {
            if(l!=1)
                sum=v2[r-1]-v2[l-2];
            else if (r==l)
                sum=v2[r-1];
            else if (l==1)
                sum=v2[r-1];
        }
        cout<<sum<<en;
 
    }
}
